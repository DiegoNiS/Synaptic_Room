# ============================================
# Synaptic Room — Global Git Ignore
# ============================================
# Centralized rules for the entire monorepo
# (Node.js, React, Python, and OS files)

# --------------------------------------------
# General / OS
# --------------------------------------------
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --------------------------------------------
# Environment Variables (Security)
# --------------------------------------------
# Ignore every real env file at any depth, but always keep the templates.
.env
.env.*
!.env.example
!**/.env.example

# --------------------------------------------
# Logs
# --------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --------------------------------------------
# Node.js / React (Client & Server)
# --------------------------------------------
node_modules/
dist/
dist-ssr/
coverage/
*.tsbuildinfo
*.local

# --------------------------------------------
# Python / FastAPI (Agents)
# --------------------------------------------
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.pytest_cache/
.coverage
htmlcov/
