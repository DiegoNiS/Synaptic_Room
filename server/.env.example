# ============================================
# Synaptic Room — Backend Server Environment
# ============================================

# Server
PORT=3001
NODE_ENV=development

# Supabase (optional — the server runs in-memory if these are absent)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# SERVICE_ROLE bypasses Row Level Security — server-side only, never ship to a client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI Agent Service (FastAPI)
AI_AGENT_BASE_URL=http://localhost:8000
# Gemini calls routinely take 2-5s; keep this comfortably above that.
AI_AGENT_TIMEOUT_MS=15000
AI_AGENT_MAX_RETRIES=2
# Shared secret sent as a header to the agents API. Must match AGENT_API_KEY there.
AGENT_API_KEY=your-internal-agent-api-key-here

# CORS — the browser origin the client is served from
CORS_ORIGIN=http://localhost:5173

# Auth
# Secret used to sign/verify socket join tokens (HMAC-SHA256). openssl rand -hex 32
JOIN_TOKEN_SECRET=your-join-token-secret-here
# Optional passcode required to join as a teacher. Empty = allow any teacher (dev only).
TEACHER_PASSCODE=

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_MS=30000

# Trace Buffer
TRACE_BUFFER_WINDOW_SIZE=5
TRACE_BUFFER_FLUSH_INTERVAL_MS=3000
