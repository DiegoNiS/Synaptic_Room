# ============================================
# Synaptic Room — Backend Server Environment
# ============================================

# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI Agent Service (Diego's FastAPI)
AI_AGENT_BASE_URL=http://localhost:8000
AI_AGENT_TIMEOUT_MS=2000
AI_AGENT_MAX_RETRIES=3

# CORS
CORS_ORIGIN=http://localhost:5173

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_MS=30000

# Trace Buffer
TRACE_BUFFER_WINDOW_SIZE=5
TRACE_BUFFER_FLUSH_INTERVAL_MS=3000
