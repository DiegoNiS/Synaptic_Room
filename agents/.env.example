# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Shared secret required on inbound requests from the Node server.
# Must match AGENT_API_KEY in the server environment. Generate with: openssl rand -hex 32
AGENT_API_KEY=your-internal-agent-api-key-here

# Puerto para FastAPI local (opcional)
PORT=8000

# Gemini model + per-request timeout (seconds)
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_S=12
