# ============================================
# Synaptic Room — Global Environment (Docker)
# ============================================
# Copy this file to `.env` (which is git-ignored) and fill in REAL values.
# docker-compose reads the file literally named `.env` in this directory —
# it does NOT read `.env.example`. Never commit real secrets here.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# SERVICE_ROLE bypasses Row Level Security — keep it server-side only, never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini API (used by the agents service)
GEMINI_API_KEY=your-gemini-api-key-here

# Shared secret the Node server uses to authenticate to the agents API.
# Generate one with:  openssl rand -hex 32
AGENT_API_KEY=your-internal-agent-api-key-here

# Secret used to sign socket join tokens (HMAC). Generate with: openssl rand -hex 32
JOIN_TOKEN_SECRET=your-join-token-secret-here

# Optional: passcode teachers must supply to open the teacher dashboard.
# Leave empty in dev to allow any teacher; set a value for real deployments.
TEACHER_PASSCODE=
